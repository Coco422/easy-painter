APP_PORT=8080

POSTGRES_DB=easy_painter
POSTGRES_USER=easy_painter
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+psycopg://easy_painter:change-me-postgres-password@postgres:5432/easy_painter

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-minio-password
MINIO_BUCKET=easy-painter-media
MINIO_REFERENCE_BUCKET=easy-painter-references
MINIO_SECURE=false

APP_NAME=easy-painter-api
SITE_NAME=安落滢绘画站
APP_ENV=production
PROMPT_MAX_LENGTH=500
GALLERY_LIMIT=24
POLLING_INTERVAL_MS=2000
GENERATE_RATE_LIMIT_COUNT=2
GENERATE_RATE_LIMIT_WINDOW_SECONDS=60

DEFAULT_MODEL=gpt-image-2-c
PUBLIC_MODELS_JSON=[{"id":"gpt-image-2-c","label":"GPT-Image-2","enabled":true}]
EXAMPLE_PROMPTS_JSON=["春天清晨的湖边小镇，薄雾、樱花和温暖阳光，治愈系插画风格","一只坐在月球咖啡馆里的橘猫，窗外是星云与地球，梦幻绘本风","海边黄昏的小火车站，远处灯塔亮起，柔和水彩质感","雨后古城的小巷，青石路反射暖色灯光，电影感场景设计"]
ALLOWED_ORIGINS_JSON=["http://localhost:5173","http://127.0.0.1:5173"]

UPSTREAM_BASE_URL=https://your-private-upstream.example.com
UPSTREAM_API_KEY=replace-with-your-private-key
UPSTREAM_TIMEOUT_SECONDS=180
UPSTREAM_DEFAULT_SIZE=auto
UPSTREAM_DEFAULT_QUALITY=high
UPSTREAM_DEFAULT_OUTPUT_FORMAT=jpeg
UPSTREAM_DEFAULT_OUTPUT_COMPRESSION=85
UPSTREAM_DEFAULT_BACKGROUND=auto
UPSTREAM_DEFAULT_MODERATION=auto
